# Copia este archivo como `.env` y ajusta los valores.

# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite (por defecto). La ruta es relativa a la carpeta prisma/.
DATABASE_URL="file:./data/hebreos11.db"

# Para migrar a PostgreSQL en el futuro:
#   1) En prisma/schema.prisma cambia  provider = "postgresql"
#   2) Usa una URL como la siguiente y ejecuta `npm run db:migrate`
# DATABASE_URL="postgresql://usuario:password@localhost:5432/hebreos11?schema=public"
